{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "type": "stat", "title": "Incidents (last 1h)",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "sum(increase(shdpa_incidents_total[1h]))"}],
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "unit": "none"}}
    },
    {
      "type": "stat", "title": "Resolution rate (last value)",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "shdpa_last_resolution_rate"}],
      "fieldConfig": {"defaults": {"unit": "percentunit", "thresholds": {"mode":"absolute","steps":[{"color":"red","value":null},{"color":"orange","value":0.6},{"color":"green","value":0.85}]}}}
    },
    {
      "type": "stat", "title": "$ spent (last 24h)",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "sum(increase(shdpa_llm_cost_usd_total[24h]))"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD"}}
    },
    {
      "type": "stat", "title": "p95 incident latency",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le) (rate(shdpa_incident_latency_seconds_bucket[1h])))"}],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "type": "timeseries", "title": "Incidents by class (5m rate)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [{"expr": "sum by (predicted_class) (rate(shdpa_incidents_total[5m]))", "legendFormat": "{{predicted_class}}"}]
    },
    {
      "type": "timeseries", "title": "Cost by provider",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [{"expr": "sum by (provider) (rate(shdpa_llm_cost_usd_total[5m]))", "legendFormat": "{{provider}}"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD"}}
    },
    {
      "type": "timeseries", "title": "Guardrail blocks by rule",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [{"expr": "sum by (rule) (rate(shdpa_guardrail_blocks_total[15m]))", "legendFormat": "{{rule}}"}],
      "alert": {
        "name": "Forbidden-path attack burst",
        "for": "5m",
        "conditions": [{"evaluator":{"params":[10],"type":"gt"},"operator":{"type":"and"},"query":{"params":["A","15m","now"]},"reducer":{"params":[],"type":"sum"},"type":"query"}]
      }
    },
    {
      "type": "heatmap", "title": "Per-incident cost distribution",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [{"expr": "sum by (le) (increase(shdpa_incident_cost_usd_bucket[5m]))", "format": "heatmap"}]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["shdpa"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "title": "shdpa — Self-Healing Data Pipeline Agent",
  "uid": "shdpa-overview",
  "version": 1
}
