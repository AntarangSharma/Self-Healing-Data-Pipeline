# Copy to .env and fill in.
# Anything left blank falls back to the safe defaults (mock LLM, dryrun escalation).

# --- LLM provider ---
SHDPA_LLM_PROVIDER=mock          # mock | anthropic | openai | ollama
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
SHDPA_ANTHROPIC_MODEL=claude-3-5-sonnet-latest
SHDPA_OPENAI_MODEL=gpt-4o-mini
SHDPA_PROMPT_VERSION=v3

# --- Escalation channels (optional) ---
SHDPA_SLACK_WEBHOOK_URL=
SHDPA_PAGERDUTY_ROUTING_KEY=
SHDPA_ESCALATION_DRYRUN=1        # 1 = log only; 0 = actually POST

# --- Safety limits ---
SHDPA_DRY_RUN=true
SHDPA_PER_INCIDENT_USD_CAP=0.05
SHDPA_TOTAL_USD_CAP=30.0

# --- Production hardening (leave unset for local dev) ---
# SHDPA_ALLOWED_REPOS=/srv/airflow-dags/*:/srv/dbt/*
# SHDPA_DISABLE_REDACTION=0
