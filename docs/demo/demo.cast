[0.701823, "o", "$ # === Self-Healing Data Pipeline Agent — 60-second demo ===\r\n"]
[1.80474, "o", "$ # 1. Generate 50 deterministic chaos fixtures (5 per failure class)\r\n"]
[2.826029, "o", "$ shdpa gen-fixtures --out fixtures --n-per-class 5\r\n"]
[3.828163, "o", "    raise CalledProcessError(retcode, process.args,\r\n                             output=stdout, stderr=stderr)\r\nsubprocess.CalledProcessError: Command '['git', '-C', 'fixtures/upstream_5xx__seed_000/repo', 'commit', '-q', '-m', 'initial']' returned non-zero exit status 1.\r\n"]
[4.848279, "o", "\r\n"]
[4.848421, "o", "$ # 2. Run all four policies (B0 restart, B1 rules, B2 single-shot LLM, Ours)\r\n"]
